# Silvora Backend Configuration (Environment Variables)

# ─── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_DEBUG=False

# ─── Database ─────────────────────────────────────────────────
# Leave empty for local SQLite (db.sqlite3)
DATABASE_URL=

# ─── Cloudflare R2 (MVP Storage) ──────────────────────────────
# ⚠️ ROTATE THESE IMMEDIATELY IF EXPOSED IN SETTINGS.PY
R2_ACCOUNT_ID=
R2_BUCKET_NAME=silvora-files
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── CORS / Security ─────────────────────────────────────────
# Comma-separated list for production
ALLOWED_HOSTS=api.silvora.cloud,silvora.cloud,localhost
CORS_ALLOWED_ORIGINS=https://silvora.cloud,https://app.silvora.cloud
